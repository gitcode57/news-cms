 <div id="admin-content">
      <div class="container">
          <div class="row">
              <div class="col-md-10">
                  <h1 class="admin-heading"><i class="fa fa-file-text"></i> All Articles</h1>
              </div>
              <div class="col-md-2">
                  <a class="add-new" href="/admin/add-article">Add New Article</a>
              </div>
              <div class="col-md-12">
               <div id="articletable"></div>
              </div>
          </div>
      </div>
  </div>

  
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://unpkg.com/tabulator-tables@6.0.0/dist/js/tabulator.min.js"></script>

  <script>
const tableData = <%- JSON.stringify(articles) %>;

var table = new Tabulator("#articletable", {
    data: tableData,
    layout: "fitColumns",
    pagination: true,
    paginationSize: 5,

    columns: [
        { title: "S.No", formatter: "rownum", hozAlign: "center", width: 100 },
        { title: "Title", field: "title", headerFilter: "input" },
        { title: "Category", field: "category.name", headerFilter: "input" },
        { title: "Author", field: "author.fullname", headerFilter: "input" },
        { title: "Date", field: "createdAt", headerFilter: "input" 
            , formatter: function(cell) {
                    const date = new Date(cell.getValue());
                    const day = date.getDate().toString().padStart(2, '0');
                    const month = date.toLocaleString('default', { month: 'long' }).split(' ')[0];
                    const year = date.getFullYear().toString();
                    return `${day}-${month}-${year}`;
                    return date.toLocaleDateString() + ' ' + date.toLocaleTimeString();

                }
        },


        {
            title: "Actions",
            formatter: function(cell) {
                const id = cell.getRow().getData()._id;

                return `
                    <a href="/admin/update-article/${id}" class="btn btn-sm btn-success">Edit</a>
                    <button class="btn btn-sm btn-danger" onclick="deleteArticle('${id}')">Delete</button>
                `;
            }
        }
    ],
});

async function deleteArticle(id) {
    try {
        if (confirm("Are you sure you want to delete this article?")) {
            const response = await fetch(`/admin/delete-article/${id}`, {
                method: 'DELETE'
            })
             if (response.ok){
            window.location.reload();
        }
        }
       
    } catch (error) {
        console.log(error);
        
    }
   
}


</script>
<%- contentFor('tabulatorCSS') %>
   <link href="https://unpkg.com/tabulator-tables@6.0.0/dist/css/tabulator.min.css" rel="stylesheet">
    <link href="dist/css/tabulator_bootstrap5.min.css" rel="stylesheet">
 